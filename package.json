{
  "name": "content-studio-dev",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "app": "concurrently -n \"backend,frontend\" -c \"cyan,magenta\" \"python mock_backend.py\" \"npm run dev --prefix frontend\""
  },
  "nodemonConfig": {
    "watch": [
      "server.js"
    ],
    "ext": "js",
    "ignore": [
      "frontend/**",
      "backend/**",
      "node_modules/**"
    ]
  },
  "dependencies": {
    "express": "^4.21.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.0"
  }
}
